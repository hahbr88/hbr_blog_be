# Postgres (Docker Compose variables)
POSTGRES_DB=hbr_blog
POSTGRES_USER=hbr
POSTGRES_PASSWORD=여기에비번

# SQLAlchemy DB URL (compose에서 db라는 서비스 이름으로 접근)
DATABASE_URL=postgresql+psycopg://xxxxxxxxxxxxxxxxxxxxxxxx

# ✅ 환경 모드
ENV=dev

# ✅ 로컬 개발용 관리자 토큰 (Next에서 X-ADMIN-TOKEN으로 보내는 값과 동일하게)
DEV_ADMIN_TOKEN=안알랴줌엄청긴거임

# (옵션) IP 제한 (비우면 제한 없음)
ADMIN_ALLOWED_IPS=

# 프록시/ALB 뒤에 둘 때만 (로컬 compose면 보통 false)
TRUST_X_FORWARDED_FOR=false
TRUSTED_PROXY_IPS=

# Cloudflare 운영용 값(로컬에선 비워도 됨)
CF_ACCESS_TEAM_NAME=
CF_ACCESS_AUD=
CF_ACCESS_ALLOWED_EMAILS=
TRUST_CF_CONNECTING_IP=false
