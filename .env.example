# Copy this file to ".env" and fill in your real values.
# cp .env.example .env

# Postgres (Docker Compose variables)
POSTGRES_DB=hbr_blog
POSTGRES_USER=hbr
POSTGRES_PASSWORD=여기에비번

# Optional: local port mappings (if you want to parameterize later)
# API_PORT=8152
# DB_PORT=5432

# 관리자 토큰
# 로컬 개발: ADMIN_ALLOWED_IPS 비우면 IP 제한 없음(토큰만 체크)
ADMIN_TOKEN=안알랴줌엄청긴거임
ADMIN_ALLOWED_IPS=

# 배포에서 프록시/ALB/NGINX 뒤에 둘 때만 True 권장
TRUST_X_FORWARDED_FOR=false
TRUSTED_PROXY_IPS=